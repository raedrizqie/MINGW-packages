@@ -147,7 +147,7 @@
       "-Wunused-macros",
     ]
 
-    if (is_win) {
+    if (is_msvc) {
       cflags += [
         # clang-cl doesn't know -pedantic, pass it explicitly to the clang driver
         "/clang:-pedantic",
@@ -160,7 +160,7 @@
     }
   }
 
